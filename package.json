{
	"name": "100apps-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "yarn vite",
		"build": "tsc -b && vite build && cp dist/index.html dist/404.html",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"preview": "yarn wrangler pages dev",
		"deploy": "yarn build && yarn wrangler pages deploy dist"
	},
	"dependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.13.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"wrangler": "^4.68.1"
	},
	"packageManager": "yarn@4.12.0"
}
